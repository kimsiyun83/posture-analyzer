# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# generated by scripts/copy-mediapipe-wasm.mjs (postinstall)
/public/mediapipe

# typescript
*.tsbuildinfo
next-env.d.ts

.vercel

/lib/generated/prisma

# local SQLite database (dev only — production points DATABASE_URL at real Postgres)
/prisma/*.db
/prisma/*.db-journal

# auto-generated Prisma CLI reference docs for AI assistants (not project content)
/.agents
/.claude
/.windsurf
/skills-lock.json
