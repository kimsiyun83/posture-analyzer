# Local SQLite by default — zero cost, zero signup. To move to production-grade
# Postgres, add Vercel Postgres (or any Postgres) from the Vercel dashboard under
# this project (free Hobby tier), change `provider = "sqlite"` to `"postgresql"`
# in prisma/schema.prisma, then set DATABASE_URL to the Postgres connection string.
DATABASE_URL="file:./prisma/dev.db"

# Any long random string. Rotate this in production — rotating invalidates all
# existing login sessions.
JWT_SECRET="change-me-to-a-long-random-string"

# Optional: seed script uses these to create the first admin account
# (defaults: admin@studio.local / changeme123 if left unset).
SEED_ADMIN_EMAIL="admin@studio.local"
SEED_ADMIN_PASSWORD="changeme123"

# Optional: only needed if you later swap the rule-based AI engine (lib/ai/*) for
# real OpenAI-backed recommendations/OCR. The app runs fully without this.
# OPENAI_API_KEY=""
